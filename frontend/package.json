{
  "name": "effinsty-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{ts,js,svelte}\" \"vite.config.ts\" \"vitest.setup.ts\" && npm run lint:ui-colors",
    "lint:ui-colors": "node scripts/lint-ui-colors.mjs",
    "test:a11y": "vitest run src/routes/login/__tests__/axe.test.ts src/routes/dashboard/contacts/__tests__/axe.test.ts \"src/routes/dashboard/contacts/[id]/__tests__/axe.test.ts\"",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest",
    "test:ci": "vitest run --coverage",
    "test:e2e": "playwright test",
    "perf:budgets": "node scripts/check-bundle-budgets.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "@sveltejs/adapter-auto": "^6.0.0",
    "@sveltejs/kit": "^2.22.0",
    "@sveltejs/vite-plugin-svelte": "^5.1.0",
    "@testing-library/jest-dom": "^6.7.0",
    "@testing-library/svelte": "^5.2.8",
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-svelte": "^3.10.1",
    "jsdom": "^26.0.0",
    "msw": "^2.11.0",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prettier-plugin-svelte": "^3.3.3",
    "svelte": "^5.23.2",
    "svelte-check": "^4.1.5",
    "svelte-eslint-parser": "^0.43.0",
    "tailwindcss": "^3.4.17",
    "vitest-axe": "0.1.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.2",
    "vitest": "^3.2.4",
    "web-vitals": "^5.1.0"
  }
}
