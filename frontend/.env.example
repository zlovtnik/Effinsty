# Public base URL for frontend API requests.
# If omitted or left blank, the frontend falls back to /api.
# In this repo, Vite loads env files from the repository root (../.env*).
#
# Example values:
# PUBLIC_API_URL=/api
# PUBLIC_API_URL=http://localhost:3000/api
# PUBLIC_API_URL=https://api.yourdomain.com/api
PUBLIC_API_URL=
