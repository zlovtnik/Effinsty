{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Effinsty.Infrastructure.OracleConnectionFactory": "Warning",
      "Effinsty.Infrastructure.OracleContactRepository": "Warning",
      "Effinsty.Infrastructure.OracleUserRepository": "Warning",
      "Effinsty.Infrastructure.DbStartupValidationService": "Information"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "effinsty-api",
    "Audience": "effinsty-clients",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7,
    "DefaultAccessScopes": [
      "contacts.read",
      "contacts.write",
      "contacts.delete"
    ],
    "TenantAccessScopes": {
      "tenant-a": [
        "contacts.read",
        "contacts.write",
        "contacts.delete"
      ],
      "tenant-b": [
        "contacts.read"
      ]
    }
  },
  "Oracle": {
    "WalletLocation": null,
    "TnsAdmin": null,
    "DataSource": null,
    "ConnectionTimeoutSeconds": 30
  },
  "Redis": {
    "Configuration": "localhost:6379",
    "KeyPrefix": "effinsty"
  },
  "Tenancy": {
    "Map": {
      "tenant-a": {
        "Schema": "RCS",
        "DataSourceAlias": "RCS"
      }
    }
  }
}
